# ── Local (desarrollo) ──────────────────────────────────────────
# Solo con esto alcanza para correr local con SQLite:
FOOTBALL_DATA_API_KEY=tu_api_key_aqui
ADMIN_PASSWORD=elegi_una_contraseña_para_el_admin
CRON_SECRET=cualquier_cadena_para_probar_el_cron

# ── Producción (Render) — opcionales en local ───────────────────
# Si están definidas, la app usa Turso en vez de SQLite local:
# TURSO_DATABASE_URL=libsql://...
# TURSO_AUTH_TOKEN=...
# SECRET_KEY=generar_con: python -c "import secrets;print(secrets.token_urlsafe(48))"
